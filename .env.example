# Copy to `.env` and set REAL values before running.
# Do not commit `.env`.

# MySQL
DB_ROOT_PASSWORD=
DB_NAME=msfg_calculator
DB_USER=msfg_user
DB_PASSWORD=

# Security (required)
# Generate at least 64 random characters for HS512, e.g. via `openssl rand -base64 64`
JWT_SECRET=
# Encryption key used by the app (required)
ENCRYPTION_KEY=
